[
    {
        "name": "orders_daily_sync",
        "description": "Sync orders from PG to DuckDB",
        "source": "pg_warehouse",
        "source_query": "SELECT * FROM stg_sales",
        "sink": "duckdb_warehouse",
        "sink_table": "fact_orders",
        "sink_mode": "upsert",
        "sink_key": "order_id",
        "transforms": [
            {
                "type": "filter",
                "condition": "amount > 0"
            },
            {
                "type": "rename",
                "from": "cust_id",
                "to": "customer_id"
            },
            {
                "type": "aggregate",
                "group_by": [
                    "region"
                ],
                "agg": {
                    "amount": "SUM"
                }
            }
        ],
        "alerts": {
            "on_failure": "email",
            "email": "admin@example.com"
        }
    },
    {
        "name": "csv_to_s3_sync",
        "description": "Export sales CSV to S3 as Parquet",
        "source": "sales_csv",
        "source_query": "",
        "sink": "s3_reports",
        "sink_table": "sales_export",
        "sink_mode": "replace",
        "transforms": [
            {
                "type": "filter",
                "condition": "status == 'active'"
            },
            {
                "type": "rename",
                "from": "id",
                "to": "record_id"
            }
        ],
        "alerts": {
            "on_failure": "none"
        }
    },
    {
        "name": "csv_to_pg_sync",
        "description": "Test CSV to Postgres sync",
        "source": "sales_csv",
        "source_query": "",
        "sink": "pg_sales_db",
        "sink_table": "stg_sales",
        "sink_mode": "replace",
        "transforms": [
            {
                "type": "filter",
                "condition": "amount > 100"
            }
        ],
        "alerts": {
            "on_failure": "none"
        }
    }
]