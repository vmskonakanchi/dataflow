[
    {
        "name": "pg_to_duckdb_incremental",
        "description": "Incremental sync from Postgres to DuckDB using last_run watermark",
        "source": "pg_main",
        "source_query": "SELECT * FROM orders WHERE updated_at > '{{last_run}}'",
        "sink": "duckdb_warehouse",
        "sink_table": "fact_orders",
        "sink_mode": "upsert",
        "sink_key": "order_id",
        "transforms": [
            {
                "type": "filter",
                "condition": "amount > 0"
            },
            {
                "type": "rename",
                "from": "cust_id",
                "to": "customer_id"
            }
        ],
        "alerts": {
            "on_failure": "email",
            "email": "admin@example.com",
            "on_row_count_below": 100
        }
    },
    {
        "name": "pg_to_duckdb_full",
        "description": "Full replace of a reference/lookup table",
        "source": "pg_main",
        "source_query": "SELECT * FROM dim_products",
        "sink": "duckdb_warehouse",
        "sink_table": "dim_products",
        "sink_mode": "replace",
        "transforms": [],
        "alerts": {
            "on_failure": "none"
        }
    },
    {
        "name": "mysql_to_pg",
        "description": "Sync from MySQL app DB to Postgres warehouse",
        "source": "mysql_app_db",
        "source_query": "SELECT * FROM users WHERE created_at > '{{last_run}}'",
        "sink": "pg_warehouse",
        "sink_table": "stg_users",
        "sink_mode": "append",
        "transforms": [
            {
                "type": "filter",
                "condition": "status == 'active'"
            }
        ],
        "alerts": {
            "on_failure": "email",
            "email": "admin@example.com"
        }
    },
